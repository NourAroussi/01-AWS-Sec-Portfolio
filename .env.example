# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# .env is gitignored and will NOT be pushed to GitHub
# ─────────────────────────────────────────────

# Your email for SNS security notifications
SECURITY_EMAIL=your-email@example.com

# Your GitHub username (for CodeBuild source)
GITHUB_USERNAME=your-github-username

# Slack webhook URL (optional - for incident response alerts)
SLACK_WEBHOOK_URL=

# AWS Region
AWS_REGION=us-east-1
